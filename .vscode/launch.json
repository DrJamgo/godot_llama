{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug test_grammar",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/addons/godot_llama/bin/test_grammar.linux.template_debug.x86_64",
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,

            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",

            "externalConsole": false,
            "sourceFileMap": {
                "${workspaceFolder}": "${workspaceFolder}"
            },
            "environment": [
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "${workspaceFolder}/addons/godot_llama/bin:${workspaceFolder}/third_party/llama.cpp/build_shared/bin"
                }
            ],

            "setupCommands": [
                { "text": "-enable-pretty-printing" },
                { "text": "set pagination off" }
            ],

            "preLaunchTask": "Build Debug Template"
        }
    ]
}