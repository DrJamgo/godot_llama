{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug Template",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "source venv/bin/activate && LLAMA_CPP_BUILD_DIR=\"third_party/llama.cpp/build_shared\" scons target=template_debug use_static_cpp=no -j8"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Build Debug Template (Clean)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "source venv/bin/activate && LLAMA_CPP_BUILD_DIR=\"third_party/llama.cpp/build_shared\" scons target=template_debug use_static_cpp=no -j8 -c"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}
